{{ 'trailkit.css' | asset_url | stylesheet_tag }}

<div
  id="tk-map-{{ block.id | replace: '-', '_' }}"
  class="tk-trail-map"
  style="height: {{ block.settings.map_height | default: 400 }}px; border-radius: {{ block.settings.border_radius | default: 8 }}px; overflow: hidden; position: relative;"
  data-tk-map
  data-guide-id="{{ block.settings.guide_id | escape }}"
  data-proxy-base="/apps/trailkit"
></div>

<script src="{{ 'trailkit-map.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Trail Map",
  "target": "section",
  "settings": []
}
{% endschema %}
